# Toyota 4Runner Manual Hunter Configuration
# Copy this file to .env and fill in your actual values

# ============================================================================
# REQUIRED: AUTO.DEV API CONFIGURATION
# ============================================================================
# Get your API key from: https://auto.dev/
AUTO_DEV_API_KEY=your_auto_dev_api_key_here

# ============================================================================
# DATABASE & SEARCH CONFIGURATION
# ============================================================================
DATABASE_PATH=4runner_tracker.db
SEARCH_INTERVAL_MINUTES=60
TARGET_YEAR_MIN=1984
TARGET_YEAR_MAX=2002

# ============================================================================
# LOCATION CONFIGURATION (Optional - for distance calculations)
# ============================================================================
# Use either ZIP code OR latitude/longitude (not both)
SEARCH_ZIP_CODE=
# SEARCH_LATITUDE=
# SEARCH_LONGITUDE=
SEARCH_RADIUS_MILES=

# ============================================================================
# NOTIFICATION CONFIGURATION (Optional)
# ============================================================================
NOTIFICATION_METHODS=email
EMAIL_TO=
EMAIL_FROM=
EMAIL_SMTP_SERVER=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_PASSWORD=
SLACK_WEBHOOK_URL=

# ============================================================================
# API RATE LIMITING
# ============================================================================
API_RATE_LIMIT_REQUESTS=100
API_RATE_LIMIT_WINDOW_SECONDS=60
API_RETRY_MAX_ATTEMPTS=3
API_RETRY_DELAY_SECONDS=5

# ============================================================================
# VIRTUAL MECHANIC - YOUR VEHICLE SPECIFICATIONS
# ============================================================================
# These help the AI provide targeted diagnostic assistance for your specific 4Runner
VEHICLE_MAKE=Toyota
VEHICLE_MODEL=4Runner
VEHICLE_GENERATION=1st
VEHICLE_SERIES=N60
VEHICLE_YEAR=1989
VEHICLE_ENGINE=3.0L 3VZ-E V6
VEHICLE_TRANSMISSION=5-speed manual
VEHICLE_DRIVE_TYPE=4x4